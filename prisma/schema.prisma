generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Profile {
  id        String   @id @default(uuid())
  userId    String   @unique // المعرف القادم من Clerk
  data      Json     // تخزين هيكل بيانات السيرة الذاتية المستخرج والمحسن
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}